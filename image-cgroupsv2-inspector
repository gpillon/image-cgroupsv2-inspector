def _resolve_user_path(path: str, invocation_cwd: Path) -> str:
    """Resolve a user-supplied path against the invocation working directory.

    PyInstaller one-file binaries chdir to an internal directory at startup.
    Relative paths for pull-secret, .env, output, etc. must be resolved
    against where the user invoked the tool, not the post-chdir location.
    """
    candidate = Path(path)
    if candidate.is_absolute():
        return str(candidate.resolve())
    return str((invocation_cwd / candidate).resolve())


def _resolve_cli_paths(args: argparse.Namespace, invocation_cwd: Path) -> None:
    """Resolve relative CLI paths before os.chdir(script_dir)."""
    for name in ("pull_secret", "env_file", "output_dir", "log_file", "rootfs_path", "state_dir"):
        value = getattr(args, name, None)
        if value:
            setattr(args, name, _resolve_user_path(value, invocation_cwd))
    if args.report_only is not None:
        args.report_only = _resolve_user_path(args.report_only, invocation_cwd)


def _normalize_registry_url(url: str) -> str:
    """Prepend https:// when the user omits the scheme."""
    if not url.startswith(("http://", "https://")):
        url = f"https://{url}"
    return url.rstrip("/")


def _build_state_file_path(target: str, state_dir: str) -> str:
    """Return the full path to the state file for *target*."""
    return str(Path(state_dir) / ScanState.build_state_filename(target))


def _handle_clean_state(target: str, state_dir: str) -> int:
    """Delete the state file for *target* and return exit code 0."""
    path = _build_state_file_path(target, state_dir)
    if Path(path).exists():
        os.remove(path)
        print(f"State file removed: {path}")
    else:
        print("No state file found")
    return 0


